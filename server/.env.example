# Copy to .env and fill in. Never commit .env.
PORT=5000
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/eniola?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=7d

# Seed admin (used by npm run seed)
ADMIN_EMAIL=admin@eniola.com
ADMIN_PASSWORD=Admin123!

# Cloudinary (optional in dev; required in production so uploads survive redeploys).
# If unset, uploads fall back to local disk in server/uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
